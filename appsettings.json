{
  "ConnectionStrings": {
    "NotificationDb": "Server=.;Database=NotificationServiceDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "NotificationEmails": {
